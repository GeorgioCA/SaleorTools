# ============================================
# Saleor Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# ============================================

# --- Core Settings ---
SECRET_KEY=change-me-to-a-long-random-string
RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
RSA_PRIVATE_PASSWORD=
DEBUG=False

# --- URLs ---
PUBLIC_URL=https://api.yourdomain.com/
DASHBOARD_URL=https://dashboard.yourdomain.com/
ALLOWED_HOSTS=api.yourdomain.com
ALLOWED_CLIENT_HOSTS=https://dashboard.yourdomain.com,https://storefront.yourdomain.com

# --- Database ---
POSTGRES_USER=saleor
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=saleor

# --- Email ---
EMAIL_URL=smtp://username:password@smtp.yourprovider.com:587/?tls=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# --- Store Defaults ---
DEFAULT_COUNTRY=US
DEFAULT_CURRENCY=USD

# --- Dashboard ---
DASHBOARD_ALLOW_SIGNUP=false
